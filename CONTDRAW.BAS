CONST DESKTOP_PATTERN = 7              ' Definition for ControlPanel array element.

DEFINT A-Z
' Desktop drawing routine for Control Panel Program.
'
' Creates custom text-mode (ASCII) picture to be displayed
' on the application desktop.  Add code here to create the
' additional pictures you want to be able to display.
' Use COLOR, LOCATE and PRINT statements to display characters.
'
SUB DrawDesktopPicture (pictnum AS INTEGER)
    ' Output to desktop (screen) only allowed when forms
    ' are not showing.
    SCREEN.HIDE
    x = DOEVENTS()

    ' Define constants corresponding to different pictures.
    CONST LOGO = 1
    CONST BRICKS = 2
    CONST WINDOWS = 3

    ' Draw selected picture.  Add new pictures within
    ' the SELECT CASE/END SELECT statements.
    SELECT CASE pictnum
    CASE LOGO:
        COLOR 7, 0
        CLS
        COLOR 0, 7
        IF SCREEN.Height < 50 THEN
            LOCATE 2, 20
        ELSE
            LOCATE 4, 20
        END IF

        IF SCREEN.Height > 25 THEN
            PRINT "                                      ": LOCATE , 20
        END IF
        PRINT " ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ ": LOCATE , 20
        PRINT " ｳ                                  ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ                                  ｳ ": LOCATE , 20
            PRINT " ｳ                                  ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
            PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛ       ﾛﾛ       ﾛﾛ       ｳ ": LOCATE , 20
        PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ       ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ       ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ                                  ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ                                  ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ      Visual Basic for MS-DOS     ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ                                  ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ        C h a r a c t e r         ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ                                  ｳ ": LOCATE , 20
        END IF
        PRINT " ｳ          W i n d o w s           ｳ ": LOCATE , 20
        PRINT " ｳ                                  ｳ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT " ｳ                                  ｳ ": LOCATE , 20
            PRINT " ｳ                                  ｳ ": LOCATE , 20
            PRINT " ｳ                                  ｳ ": LOCATE , 20
            PRINT " ｳ                                  ｳ ": LOCATE , 20
        END IF
        PRINT " ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT "                                      ";
        END IF

        IF SCREEN.Height = 25 THEN
            TopWindow = 4
            LowerWindow = 5
            LeftWindow = 31
            SizeWindow = 5
        ELSEIF SCREEN.Height = 43 THEN
            TopWindow = 8
            LowerWindow = 10
            LeftWindow = 31
            SizeWindow = 8
        ELSE
            TopWindow = 10
            LowerWindow = 12
            LeftWindow = 31
            SizeWindow = 8
        END IF

        COLOR 4
        FOR i% = 1 TO SizeWindow
            LOCATE TopWindow + i%, LeftWindow
            PRINT "ﾛﾛﾛﾛﾛﾛﾛ";
        NEXT i%

        COLOR 2
        FOR i% = 1 TO SizeWindow
            LOCATE TopWindow + i%, LeftWindow + 9
            PRINT "ﾛﾛﾛﾛﾛﾛﾛ";
        NEXT i%

        COLOR 1
        FOR i% = 1 TO SizeWindow
            LOCATE LowerWindow + SizeWindow + i%, LeftWindow
            PRINT "ﾛﾛﾛﾛﾛﾛﾛ";
        NEXT i%

        COLOR 14
        FOR i% = 1 TO SizeWindow
            LOCATE LowerWindow + SizeWindow + i%, LeftWindow + 9
            PRINT "ﾛﾛﾛﾛﾛﾛﾛ";
        NEXT i%

    CASE BRICKS:
        COLOR 7, 0
        CLS
        COLOR 0, 4
        BrickTop$ = "ﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄ"
        BrickBottom$ = "ﾁ"
        FOR i% = 1 TO SCREEN.Height - 1 STEP 2
            LOCATE i%, 1
            PRINT LEFT$(BrickTop$, 80);
            LOCATE i% + 1, 1
            PRINT RIGHT$(BrickTop$, 80);

            FOR j% = 3 TO 80 STEP 8
            LOCATE i%, j%
            PRINT BrickBottom$;
            NEXT j%

            FOR j% = 7 TO 80 STEP 8
            LOCATE i% + 1, j%
            PRINT BrickBottom$;
            NEXT j%
        NEXT i%

        IF SCREEN.Height < 50 THEN
            LOCATE SCREEN.Height, 1
            PRINT LEFT$(BrickTop$, 80);

            FOR j% = 3 TO 80 STEP 8
            LOCATE SCREEN.Height, j%
            PRINT BrickBottom$;
            NEXT j%
        END IF

    CASE WINDOWS:
        COLOR 7, 0
        CLS
        COLOR 14, 0
        IF SCREEN.Height = 25 THEN
            LOCATE 4, 20
        ELSEIF SCREEN.Height = 43 THEN
            LOCATE 10, 20
        ELSE
            LOCATE 12, 20
        END IF

        PRINT "ﾚﾄﾄﾄﾄﾄﾄﾄｿﾚﾄﾄﾄﾄﾄﾄﾄｿ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        END IF
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ﾀﾄﾄﾄﾄﾄﾄﾄﾙﾀﾄﾄﾄﾄﾄﾄﾄﾙﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ﾚﾄﾄﾄﾄﾄﾄﾄｿﾚﾄﾄﾄﾄﾄﾄﾄｿﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        END IF
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ｳﾛﾛﾛﾛﾛﾛﾛｳｳﾛﾛﾛﾛﾛﾛﾛｳﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "ﾀﾄﾄﾄﾄﾄﾄﾄﾙﾀﾄﾄﾄﾄﾄﾄﾄﾙﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT " ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "   ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "     ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "      ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "        ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        PRINT "          ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        IF SCREEN.Height > 25 THEN
            PRINT "           ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
            PRINT "              ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
            PRINT "                ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
            PRINT "                   ﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛﾛ": LOCATE , 20
        END IF

    END SELECT

    ' Preserve picture by setting element 7 (DESKTOP_PATTERN)
    ' of ControlPanel array to 0 (nul).  Note, a redraw buffer
    ' is used to save the image and will reduce the amount of
    ' available memory in your application.
    SCREEN.ControlPanel(DESKTOP_PATTERN) = 0

    ' Show forms on top of desktop.
    SCREEN.SHOW
    x = DOEVENTS()
END SUB

